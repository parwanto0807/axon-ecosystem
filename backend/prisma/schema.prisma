model OperationalExpense {
  id              String         @id @default(cuid())
  name            String         // e.g., "Listrik Kantor", "Internet"
  category        String         // e.g., "Utilities", "Rent"
  amount          Float          @default(0)
  month           Int
  year            Int
  date            DateTime       @default(now())
  status          ExpenseStatus  @default(DRAFT)
  
  coaId           String         // The specific expense account (6-xxxx)
  coa             ChartOfAccounts @relation(fields: [coaId], references: [id])
  
  journalId       String?        // Link to the posting JV
  paymentJournalId String?       // Link to the payment JV
  paymentCoaId    String?        // Account used for payment (Bank/Cash)
  paidAt          DateTime?
  attachment      String?        // Path to the uploaded proof (webp)
  
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
}



model CustomerAsset {
  id               String        @id @default(cuid())
  customerId       String
  name             String        // e.g., "Server Utama", "AC Ruang Meeting"
  category         AssetCategory @default(GENERAL)

  brand            String?       // e.g., "Dell", "Daikin"
  model            String?       // e.g., "PowerEdge R740", "FTKC25TVM"
  serialNumber     String?       @unique
  location         String?       // e.g., "Data Center Lt. 1", "R. Meeting"

  // Flexible technical specs (RAM, CPU, IP, Refrigerant, Capacity, etc.)
  specifications   Json?

  installationDate DateTime?
  lastServiceDate  DateTime?
  nextServiceDate  DateTime?     // For auto-reminder
  status           AssetStatus   @default(ACTIVE)
  notes            String?

  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  customer         Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  workOrders       WorkOrder[]
  businessCategoryId String?
  businessCategory   BusinessCategory? @relation(fields: [businessCategoryId], references: [id])
}

enum AssetCategory {
  AC
  IT
  ELECTRONIC
  VEHICLE
  FURNITURE
  GENERAL
}

enum AssetStatus {
  ACTIVE
  INACTIVE
  BROKEN
  REPLACED
  SCRAPPED
}
